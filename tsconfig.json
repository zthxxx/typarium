{
  "include": [
    "packages/*/src/**/*",
    "apps/web/src/**/*",
    "apps/web/e2e/**/*",
    "apps/web/scripts/**/*",
    "apps/web/vite.config.ts",
    "apps/web/playwright.config.ts",
    "eslint.config.js",
    "prettier.config.js",
    "vitest.config.ts"
  ],

  "compilerOptions": {
    "target": "ES2022",
    "jsx": "react-jsx",
    "module": "ESNext",
    "paths": {
      "#/*": ["./apps/web/src/*"],
      "@/*": ["./apps/web/src/*"]
    },
    "lib": ["ES2022", "DOM", "DOM.Iterable"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "customConditions": ["typarium-source"],
    "allowImportingTsExtensions": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,

    /* Linting */
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedSideEffectImports": true
  }
}
