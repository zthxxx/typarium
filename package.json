{
  "name": "typarium",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @typarium/web dev",
    "build": "pnpm --filter @typarium/web build",
    "preview": "pnpm --filter @typarium/web preview",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @typarium/web test:e2e",
    "perf:cold": "pnpm --filter @typarium/web perf:cold",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@playwright/test": "^1.61.1",
    "@tanstack/eslint-config": "^0.4.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.10.2",
    "eslint": "^10.7.0",
    "fast-check": "^4.9.0",
    "jsdom": "^28.1.0",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "typescript": "6.0.3",
    "vitest": "^4.1.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "simple-git-hooks"
    ]
  },
  "packageManager": "pnpm@9.15.9"
}
