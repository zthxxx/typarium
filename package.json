{
  "name": "typarium",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @typarium/web dev",
    "build": "pnpm --filter @typarium/web build",
    "preview": "pnpm --filter @typarium/web preview",
    "build:packages": "pnpm -r --filter './packages/*' build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "test:e2e": "pnpm --filter @typarium/web test:e2e",
    "perf:cold": "pnpm --filter @typarium/web perf:cold",
    "lint": "eslint",
    "format": "prettier --write . && eslint --fix",
    "check": "prettier --check .",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged",
    "commit-msg": "pnpm exec commitlint --edit $1"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,json,css,md}": [
      "prettier --write"
    ]
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "catalog:",
    "@commitlint/config-conventional": "catalog:",
    "@playwright/test": "catalog:",
    "@tanstack/eslint-config": "catalog:",
    "@testing-library/dom": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "fast-check": "catalog:",
    "jsdom": "catalog:",
    "lint-staged": "catalog:",
    "prettier": "catalog:",
    "simple-git-hooks": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss",
      "simple-git-hooks"
    ]
  },
  "packageManager": "pnpm@9.15.9"
}
