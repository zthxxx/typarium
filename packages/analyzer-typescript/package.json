{
  "name": "@typarium/analyzer-typescript",
  "version": "0.1.0",
  "description": "The TypeScript language analyzer for typarium: checker-level containment matrix, witness-corrected assignability, editor language features. Node-usable; worker/transport glue stays with the host app",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "typarium-source": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./descriptor": {
      "typarium-source": "./src/descriptor.ts",
      "types": "./dist/descriptor.d.ts",
      "default": "./dist/descriptor.js"
    },
    "./node": {
      "typarium-source": "./src/lib-files.node.ts",
      "types": "./dist/lib-files.node.d.ts",
      "default": "./dist/lib-files.node.js"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json"
  },
  "dependencies": {
    "@typarium/language-adapter": "workspace:*",
    "@typarium/set-model": "workspace:*",
    "@typescript/ata": "catalog:",
    "@typescript/vfs": "catalog:",
    "twoslash": "catalog:",
    "typescript": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:"
  }
}
