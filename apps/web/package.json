{
  "name": "@typarium/web",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "node scripts/generate-ts-libs.mjs && vite dev --port 3000",
    "generate-routes": "tsr generate",
    "generate-sample-snapshot": "node --conditions typarium-source --experimental-strip-types scripts/generate-sample-snapshot.mts",
    "build": "node scripts/generate-ts-libs.mjs && pnpm generate-sample-snapshot && vite build && node scripts/inject-preload.mjs",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "perf:cold": "node scripts/measure-cold-start.mjs"
  },
  "dependencies": {
    "@floating-ui/core": "catalog:",
    "@heroicons/react": "catalog:",
    "@tanstack/react-router": "catalog:",
    "@tanstack/react-start": "catalog:",
    "@typarium/analyzer-typescript": "workspace:*",
    "@typarium/diagram-euler": "workspace:*",
    "@typarium/diagram-hasse": "workspace:*",
    "@typarium/language-adapter": "workspace:*",
    "@typarium/set-model": "workspace:*",
    "comlink": "catalog:",
    "idb": "catalog:",
    "lz-string": "catalog:",
    "mobx": "catalog:",
    "mobx-react-lite": "catalog:",
    "monaco-editor": "catalog:",
    "power-di": "catalog:",
    "prettier": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "tailwindcss": "catalog:"
  },
  "devDependencies": {
    "@playwright/test": "catalog:",
    "@tailwindcss/vite": "catalog:",
    "@tanstack/devtools-vite": "catalog:",
    "@tanstack/react-devtools": "catalog:",
    "@tanstack/react-router-devtools": "catalog:",
    "@tanstack/react-router-ssr-query": "catalog:",
    "@tanstack/router-cli": "catalog:",
    "@tanstack/router-plugin": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
